{
    "split_seed": 123,
    "data_augmentations": [],
    "builds": {
        "sft": {
            "output_suffix": "_sft",
            "validation_split_fraction": 0.1,
            "tokenizer_name_or_path": "meta-llama/Llama-3.3-70B-Instruct",
            "max_length": 2048,
            "enable_chunking": true,
            "chunk_at_markdown_headers": true,
            "prompt_format": "chat",
            "data_pipelines": [
                {
                    "name": "basic",
                    "sources": [
                        {
                            "folder": "corpus"
                        }
                    ]
                }
            ]
        },
        "dpo": {
            "output_suffix": "_dpo",
            "validation_split_fraction": 0.1,
            "tokenizer_name_or_path": "meta-llama/Llama-3.3-70B-Instruct",
            "max_length": 1024,
            "enable_chunking": false,
            "chunk_at_markdown_headers": true,
            "prompt_format": "chat",
            "data_pipelines": [
                {
                    "name": "contrast_pairs",
                    "sources": [
                        {
                            "folder": "augmentations/contrast_pairs"
                        }
                    ]
                }
            ]
        }
    }
}