{
  "split_seed": 42,
  "builds": {
    "sft": {
      "output_suffix": "_sft",
      "validation_split_fraction": 0.3,
      "tokenizer_name_or_path": "distilbert/distilgpt2",
      "max_length": 100,
      "enable_chunking": true,
      "chunk_at_markdown_headers": true,
      "prompt_format": "text",
      "data_pipelines": [
        {
          "name": "basic",
          "sources": [
            {
              "folder": "corpus"
            }
          ]
        }
      ],
      "chunk_overlap_ratio": 0.2
    }
  }
}