{
    "model": "gemma-3-27b-pt",
    "dataset_config_name": "adam_dataset_pt",
    "peft_config_name": "lora_default",
    "run_name": "adam_clone2",
    "output_dir": "experiments",
    "overwrite_output_dir": false,
    "max_steps": -1,
    "max_seq_length": 2048,
    "num_train_epochs": 5.0,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 4,
    "learning_rate": 2e-5,
    "weight_decay": 0.001,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.10,
    "logging_strategy": "steps",
    "logging_steps": 1,
    "evaluation_strategy": "no",
    "eval_steps": null,
    "save_strategy": "no",
    "save_steps": null,
    "save_total_limit": 1,
    "fp16": false,
    "bf16": true,
    "report_to": [
        "wandb"
    ],
    "wandb_project": "pollux",
    "seed": 42
}