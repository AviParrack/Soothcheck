{
    "output_name": "adam_sft",
    "raw_data_directory_name": "adam",
    "file_extensions": [
        ".mdx",
        ".md",
        ".jsonl"
    ],
    "validation_split_percentage": 0.2,
    "split_seed": 123,
    "enable_chunking": true,
    "chunk_at_markdown_headers": true,
    "max_length": 2048,
    "tokenizer_name_or_path": "google/gemma-3-27b-it",
    "prompt_format": "chat",
    "data_augmentations": [
        {
            "name": "qa",
            "sources": [
                {"folder": "corpus"}
            ]
        }
    ],
    "data_pipelines": [
        {
            "name": "basic",
            "sources": [
                {"folder": "corpus"}
            ]
        },
        {
            "name": "continues",
            "sources": [
                {"folder": "corpus"}
            ],
            "min_grab_length": 250,
            "max_grab_length": 1000
        },
        {
            "name": "qa",
            "sources": [
                {"folder": "augmented", "file_regex": "qa\\.jsonl$"}
            ]
        }
    ]
} 