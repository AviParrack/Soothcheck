{
    "model": "gemma-3-1b-it",
    "dataset_config_name": "sample_dataset",
    "peft_config_name": "lora_default",
    "run_name": "gemma-3-1b-it_lora_example",
    "output_dir": "experiments",
    "overwrite_output_dir": false,
    "max_steps": 10,
    "max_length": 2048,
    "num_train_epochs": 1.0,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "learning_rate": 3e-4,
    "weight_decay": 0.001,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.03,
    "logging_strategy": "steps",
    "logging_steps": 10,
    "evaluation_strategy": "no", 
    "eval_steps": null,
    "save_strategy": "epoch",
    "save_steps": null,
    "save_total_limit": 1,
    "fp16": false,
    "bf16": true,
    "report_to": ["wandb"],
    "wandb_project": "pollux",
    "seed": 42
} 