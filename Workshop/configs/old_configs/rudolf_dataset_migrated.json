{
    "split_seed": 123,
    "data_augmentations": [
        {
            "name": "qa",
            "sources": [
                {"folder": "corpus", "file_regex": "^(?!.*\\.aug\\.).*$"}
            ]
        },
        {
            "name": "take",
            "sources": [
                {"folder": "corpus", "file_regex": "^(?!.*\\.aug\\.).*$"}
            ]
        }
    ],
    "builds": {
        "sft": {
            "output_suffix": "_sft",
            "validation_split_fraction": 0.2,
            "tokenizer_name_or_path": "google/gemma-3-27b-it",
            "max_length": 2048,
            "enable_chunking": true,
            "chunk_at_markdown_headers": true,
            "prompt_format": "chat",
            "data_pipelines": [
                {
                    "name": "basic",
                    "sources": [
                        {"folder": "corpus"}
                    ]
                },
                {
                    "name": "continues",
                    "sources": [
                        {"folder": "corpus", "file_regex": "^(?!.*\\.aug\\.).*$"}
                    ],
                    "min_grab_length": 250,
                    "max_grab_length": 1000
                }
            ]
        }
    }
} 