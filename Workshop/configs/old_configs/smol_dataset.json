{
    "output_name": "smol_dataset",
    "raw_data_directory_name": "smol_dataset",
    "file_extensions": [
        ".mdx",
        ".md",
        ".txt",
        ".jsonl"
    ],
    "validation_split_percentage": 0.01,
    "split_seed": 123,
    "enable_chunking": true,
    "chunk_at_markdown_headers": true,
    "max_length": 2048,
    "tokenizer_name_or_path": "google/gemma-3-27b-it",
    "prompt_format": "chat",
    "data_augmentations": [
        {
            "name": "qa",
            "file_regex": "^(?!.*\\.aug\\.).*$"
        }
    ],
    "data_pipelines": [
        {
            "name": "basic"
        },
        {
            "name": "continues",
            "file_regex": "^(?!.*\\.aug\\.).*$",
            "min_grab_length": 250,
            "max_grab_length": 1000
        },
        {
            "name": "qa",
            "file_regex": ".*\\.aug\\.qa\\.jsonl$"
        }
    ]
}